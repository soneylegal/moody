DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/swingbot
API_TITLE=Swing Trade Bot API
API_VERSION=0.1.0

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_MINUTES=10080

# REQUIRED — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

MARKET_STREAM_INTERVAL_SECONDS=2.0
