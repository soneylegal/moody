# Moody — Production Environment Variables (Oracle VPS)
# Copy to .env on the VPS and fill in the values.

DATABASE_URL=postgresql+psycopg://moody:moody_password@postgres:5432/moody
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=CHANGE_ME_generate_with_python3_-c_import_secrets_print_secrets_token_urlsafe_64__
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_with_python3_-c_from_cryptography_fernet_import_Fernet_print_Fernet_generate_key_decode__

CORS_ORIGINS=https://seu-dominio.com

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_MINUTES=10080

MARKET_STREAM_INTERVAL_SECONDS=2.0
BOT_AUTOMATION_INTERVAL_SECONDS=60.0

OTEL_ENABLED=false

API_TITLE="Moody API"
API_VERSION=0.1.0
